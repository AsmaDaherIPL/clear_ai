      "fontSize": 13,
      "fontFamily": 2,
      "text": "type ItemTrace = {\n  triage_branch: string;\n  merchant_code_status: 'ACTIVE'|'DELETED'|'PARTIAL'|'UNKNOWN'|'NONE';\n  merchant_code?: string;\n  replacement_codes_seen?: string[];   // DELETED branch\n\n  blind_code: string;                  // ALWAYS populated\n  blind_alternatives: string[];\n  blind_confidence: number;\n  blind_rationale: string;\n\n  reconciliation: 'agree'|'arbitrated'|'investigated'\n                  |'expanded'|'accepted_blind';\n  arbitration_winner?: 'merchant'|'blind'|'other';\n  arbitration_rationale?: string;\n\n  tenant_override_applied?: boolean;\n  tenant_override_from?: string;\n  tenant_override_to?: string;\n\n  final_code: string;\n  sanity_verdict: 'PASS'|'FLAG'|'BLOCK';\n  sanity_reason?: string;\n\n  llm_calls_used: number;              // 2 to 4 per item\n};",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "type ItemTrace = {\n  triage_branch: string;\n  merchant_code_status: 'ACTIVE'|'DELETED'|'PARTIAL'|'UNKNOWN'|'NONE';\n  merchant_code?: string;\n  replacement_codes_seen?: string[];   // DELETED branch\n\n  blind_code: string;                  // ALWAYS populated\n  blind_alternatives: string[];\n  blind_confidence: number;\n  blind_rationale: string;\n\n  reconciliation: 'agree'|'arbitrated'|'investigated'\n                  |'expanded'|'accepted_blind';\n  arbitration_winner?: 'merchant'|'blind'|'other';\n  arbitration_rationale?: string;\n\n  tenant_override_applied?: boolean;\n  tenant_override_from?: string;\n  tenant_override_to?: string;\n\n  final_code: string;\n  sanity_verdict: 'PASS'|'FLAG'|'BLOCK';\n  sanity_reason?: string;\n\n  llm_calls_used: number;              // 2 to 4 per item\n};",
      "lineHeight": 1.4
    },
