# ClearAI Frontend — environment variables
#
# These are read at BUILD time by Vite/Astro (PUBLIC_* convention) and
# baked into the JS bundle. They are NOT secrets in the cryptographic
# sense — anyone inspecting the deployed bundle can see them. APIM
# rate-limits per-key + CORS-locks origins to mitigate abuse.
#
# Copy this file to .env.local for local development. CI / Azure Static
# Web Apps reads the same names from GitHub Actions secrets in the
# frontend-deploy-azure-swa.yml workflow.

# Backend base URL.
# Local dev: http://localhost:3000 (Fastify backend on :3000).
# Production: https://apim-infp-clearai-be-dev-gwc-01.azure-api.net
PUBLIC_CLEARAI_API_BASE=http://localhost:3000

# APIM subscription key, sent as `Ocp-Apim-Subscription-Key` on every
# request. Leave empty for local dev (no key required against localhost
# Fastify); required in production where APIM enforces it.
PUBLIC_CLEARAI_API_KEY=
