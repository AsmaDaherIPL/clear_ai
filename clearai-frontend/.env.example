# Exposed to the browser (Astro's PUBLIC_ prefix). Points at the Fastify
# backend. Local dev: http://localhost:3000 (the backend's default PORT).
# Prod: the APIM gateway hostname, e.g.
#   https://apim-infp-clearai-be-dev-gwc-01.azure-api.net
# Do NOT use the Container App FQDN directly in prod — the backend's
# origin-lock rejects requests that didn't come through APIM.
PUBLIC_CLEARAI_API_BASE=http://localhost:3000

# APIM subscription key. Leave empty for local dev (the backend's
# auth hook is a no-op when NODE_ENV !== production).
# In prod (Cloudflare Pages env), paste the subscription key shown
# at the end of the APIM deploy. The client sends it as the
# `Ocp-Apim-Subscription-Key` header on every request.
PUBLIC_CLEARAI_APIM_KEY=
