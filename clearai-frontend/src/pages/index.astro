---
import Layout from '../layouts/Layout.astro';
import ClassifyApp from '../components/ClassifyApp.tsx';
---

<Layout>
  <section class="mb-10">
    <p class="font-display text-2xl md:text-3xl text-parchment-900 leading-snug max-w-3xl">
      Drop a merchant description. Get the precise
      <span class="italic text-najdi-600">12-digit Saudi HS code</span>,
      a WCO-grounded justification, and the FAISS evidence trail that got us there.
    </p>
  </section>

  <ClassifyApp client:load />
</Layout>
