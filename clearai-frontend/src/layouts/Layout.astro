---
/**
 * Root layout. Resolves locale from ?lang= → cookie → 'en', persists to cookie,
 * and runs an inline pre-hydrate script to fix dir/lang before paint.
 */

const url = new URL(Astro.request.url);
const queryLang = url.searchParams.get('lang');
const cookieLang = Astro.cookies.get('lang')?.value;

const valid = (v: string | null | undefined): v is 'en' | 'ar' =>
  v === 'en' || v === 'ar';

const locale: 'en' | 'ar' =
  valid(queryLang) ? queryLang
  : valid(cookieLang) ? cookieLang
  : 'en';

if (valid(queryLang) && queryLang !== cookieLang) {
  Astro.cookies.set('lang', queryLang, {
    path: '/',
    maxAge: 60 * 60 * 24 * 365,
    sameSite: 'lax',
  });
}

const dir = locale === 'ar' ? 'rtl' : 'ltr';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ClearAI — Customs classification with confidence',
  description = 'Saudi HS-code classification grounded in ZATCA. Retrieval + reasoning, not a guess.',
} = Astro.props;
---
<!doctype html>
<html lang={locale} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="alternate" hreflang="en" href="/?lang=en" />
    <link rel="alternate" hreflang="ar" href="/?lang=ar" />
    <link rel="alternate" hreflang="x-default" href="/" />

    {/* Sync pre-hydrate: re-apply lang/dir from cookie before first paint. */}
    <script is:inline>
      (function () {
        try {
          var m = document.cookie.match(/(?:^|; )lang=(en|ar)/);
          var qs = new URLSearchParams(window.location.search);
          var q = qs.get('lang');
          var lang = (q === 'en' || q === 'ar') ? q : (m ? m[1] : 'en');
          if (lang !== document.documentElement.getAttribute('lang')) {
            document.documentElement.setAttribute('lang', lang);
            document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
          }
        } catch (e) { /* fail-open */ }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
