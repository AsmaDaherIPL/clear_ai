---
/**
 * Root layout. Imports v5 design tokens + preloads fonts. The TopBar,
 * Hero, and Footer are rendered inside the React app so the entire
 * v5 shell is a single island.
 */
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Clear AI — Saudi HS Classification' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="An intelligent platform that improves customs classification accuracy before clearance — reducing manual effort and supporting faster, more consistent processing."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
