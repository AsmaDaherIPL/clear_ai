{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "apimName": {
      "value": "<EXISTING_APIM_INSTANCE_NAME>"
    },
    "apiId": {
      "value": "clearai-backend-v1"
    },
    "apiDisplayName": {
      "value": "ClearAI Backend API"
    },
    "apiPath": {
      "value": "api"
    },
    "backendUrl": {
      "value": "https://<CONTAINER_APP_FQDN>"
    },
    "entraTenantId": {
      "value": "<ENTRA_TENANT_ID>"
    },
    "entraAudience": {
      "value": "api://clearai-backend"
    },
    "keyVaultName": {
      "value": "<KEY_VAULT_NAME>"
    },
    "apimSharedSecretSecretName": {
      "value": "apim-shared-secret"
    },
    "corsOrigins": {
      "value": "https://app.clearai.example.com"
    },
    "rateLimitMax": {
      "value": 60
    },
    "rateLimitWindow": {
      "value": 60
    }
  }
}
