# Copy this file to .env and fill in values. Never commit .env.

# ---- LLM backend selection ----
# "api"   → Anthropic cloud (production)
# "local" → Ollama local models (offline/dev)
LLM_BACKEND=api

# ---- Confidence gating ----
# Resolutions below this confidence are flagged in review.csv
CONFIDENCE_THRESHOLD=0.75

# HV/LV tier threshold in SAR (BUILD.md §Step 8)
HV_THRESHOLD_SAR=1000.0

# ---- API backend (required if LLM_BACKEND=api) ----
ANTHROPIC_API_KEY=sk-ant-...

# Claude model names — pin specific versions for determinism
RANKER_API_MODEL=claude-sonnet-4-6
REASONER_API_MODEL=claude-opus-4-6

# ---- Local backend (required if LLM_BACKEND=local) ----
OLLAMA_BASE_URL=http://localhost:11434
RANKER_LOCAL_MODEL=phi3-mini
REASONER_LOCAL_MODEL=llama3:70b

# ---- Storage paths (relative to clearai-app/) ----
DB_PATH=clear_ai.db
FAISS_INDEX_PATH=hs_master_faiss.index
FAISS_CODES_PATH=hs_codes.json
OUTPUT_DIR=output
DATA_DIR=data
