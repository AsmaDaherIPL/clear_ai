# Copy this file to .env and fill in values. Never commit .env.

# ---- LLM provider ----
# V1 is API-only. No local inference. See ADR-004.
ANTHROPIC_API_KEY=sk-ant-...

# Three-tier model split — match each task to the smallest model that does it well.
# Pin specific versions for determinism. See ADR-004.
RANKER_MODEL=claude-sonnet-4-6        # candidate ranking: pick best from prefix shortlist
TRANSLATION_MODEL=claude-haiku-4-6    # Arabic description translation (cheap, narrow)
REASONER_MODEL=claude-opus-4-6        # hardest case: full inference from description

# ---- Confidence gating ----
# Resolutions below this confidence are flagged in review.csv
CONFIDENCE_THRESHOLD=0.75

# HV/LV tier threshold in SAR (BUILD.md §Step 8)
HV_THRESHOLD_SAR=1000.0

# ---- Storage paths (relative to clearai-app/) ----
DB_PATH=clear_ai.db
FAISS_INDEX_PATH=hs_master_faiss.index
FAISS_CODES_PATH=hs_codes.json
OUTPUT_DIR=output
DATA_DIR=data
