{
  "name": "clearai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "ClearAI v1 — ZATCA 12-digit HS classification (TypeScript + Fastify + Drizzle + pgvector)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server/app.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/app.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx local-dev/scripts/ingest-zatca-hs-codes.ts",
    "db:seed:overrides:naqel": "tsx local-dev/scripts/ingest-tenant-overrides.ts --tenant naqel",
    "db:seed:display": "tsx local-dev/scripts/ingest-zatca-hs-code-display.ts",
    "db:seed:search": "tsx local-dev/scripts/ingest-zatca-hs-code-search.ts",
    "db:seed:procedures": "tsx local-dev/scripts/ingest-zatca-procedure-codes.ts",
    "db:seed:deleted": "tsx local-dev/scripts/ingest-deleted-codes.ts",
    "db:seed:tenants": "tsx src/scripts/seed-tenants.ts",
    "db:seed:tenant-lookups": "tsx src/scripts/seed-tenant-lookups.ts",
    "db:parse:saber": "tsx local-dev/scripts/parse-saber-pdf.ts",
    "bench": "tsx local-dev/scripts/bench-classify.ts",
    "bench:expand": "tsx local-dev/scripts/bench-expand.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx local-dev/scripts/eval-run.ts",
    "eval:smoke": "tsx local-dev/scripts/eval-run.ts --limit 25 --tag smoke"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "@azure/storage-blob": "^12.31.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "p-limit": "^7.3.0",
    "pg": "^8.13.1",
    "pino-pretty": "^13.0.0",
    "uuidv7": "^1.2.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "protobufjs"
    ],
    "//": "Two transitive-dep remediations applied as lockfile overrides:\n  1. protobufjs >= 7.5.5 — GHSA arbitrary-code-execution in type-field handling of compiled definitions. We don't compile untrusted definitions but onnx-proto -> protobufjs is flagged. Swapping @xenova/transformers would require @huggingface/transformers (different API surface, retest cost), so override at lockfile level instead.\n  2. esbuild >= 0.25.0 — GHSA-67mh-4wv8-2f99 (dev-server CORS allows arbitrary requests). Pre-override we had esbuild 0.18 + 0.19 + 0.21 transitive via drizzle-kit + esbuild-register + vite. None of these run in production (build-time only), but Dependabot flags any vulnerable version in the lockfile. Override sweeps all dev-only paths to 0.25+ regardless of which dependency pulls them.",
    "overrides": {
      "protobufjs@<7.5.5": ">=7.5.5",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.10",
    "exceljs": "^4.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
