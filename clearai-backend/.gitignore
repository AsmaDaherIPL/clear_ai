# env files (never commit secrets)
.env
.env.*
!.env.example
foundryllm.env

# node
node_modules/
dist/
build/
*.tsbuildinfo

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# os
.DS_Store
Thumbs.db

# editor
.vscode/
.idea/
*.swp

# local data
pgdata/
*.local.json

# transformers.js model cache (committed via Docker layer in prod)
.cache/
models/

awesome-claude-code/

# Tracker docs — internal coordination notes (architecture decisions,
# lessons learned, test cases, V1 plan). Useful locally but reference
# deployment internals + WIP context that shouldn't live on the public
# repo. The .docx exclusion below stays for the same reason — kept for
# git-history grep; tracker/ supersedes it for new files.
tracker/
tracker/*.docx

# Local developer scaffolding — Bruno API collection (per-developer setup,
# OAuth2 client config tied to each user), the LOCAL-DEV.md walkthrough
# document, and any other ad-hoc local-dev assets. Note: local-dev/scripts/
# is intentionally NOT ignored — package.json's `db:seed`, `bench`, `eval`,
# etc. depend on those files; ignoring them would break a fresh clone.
local-dev/bruno/
LOCAL-DEV.md

# drawio auto-backups and editor scratch files
.$*.drawio.bkp
.$*.drawio.dtmp