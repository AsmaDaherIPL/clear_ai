# Local dev overrides for env.ts. Only vars whose value differs from the
# Zod schema default need to be here — defaults handle the rest.
#
# Copy to .env and fill in the required-to-set vars (no schema default).
# DO NOT COMMIT .env (already in .gitignore).

# ── Connections (no default) ─────────────────────────────────────────────
DATABASE_URL=postgres://clearai:clearai@localhost:5432/clearai

# ── Foundry / LLM (no default — must be supplied) ────────────────────────
# Copy from Foundry deployment "Details" tab. ANTHROPIC_BASE_URL must be the
# full Target URI including /v1/messages.
# Same Foundry key works for ANTHROPIC_API_KEY and FOUNDRY_EMBED_API_KEY (one
# resource exposes both surfaces).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://aif-infp-dev-swc-01.services.ai.azure.com/anthropic/v1/messages

# ── Foundry / Embedder (only API key has no default) ─────────────────────
FOUNDRY_EMBED_API_KEY=

# ── Declaration-runs blob storage (no default) ───────────────────────────
# Local-disk fallback for dev: file://./.local-blob
# Prod: secretref to an Azure Blob connection string in Key Vault.
BATCH_BLOB_CONNECTION=file://./.local-blob

# ZATCA submitter credentials moved to per-operator columns on the
# operators table (see migration 0062). No env var equivalents.

# ── Optional overrides (uncomment to deviate from schema defaults) ───────
# LLM_MODEL=claude-haiku-4-5-clearai-dev
# LLM_MODEL_STRONG=claude-sonnet-4-6-clearai-dev
# LLM_TIMEOUT_MS=15000
# FOUNDRY_EMBED_ENDPOINT=https://aif-infp-dev-swc-01.services.ai.azure.com
# FOUNDRY_EMBED_MODEL=text-embedding-3-large-clearai-dev
# FOUNDRY_EMBED_DIM=1024
# PORT=3000
# LOG_LEVEL=info
# NODE_ENV=development
# CORS_ORIGINS=https://clearai.pages.dev,https://apim-infp-clearai-be-dev-gwc-01.azure-api.net
# APIM_SHARED_SECRET=         # required in prod (NODE_ENV=production)
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW=1 minute
# BATCH_LLM_CONCURRENCY=8
# BATCH_INPUT_MAX_ROWS=1000
# BATCH_BLOB_CONTAINER=batches
# BATCH_FX_RATES_TO_SAR={"AED":1.02,"USD":3.75,"EUR":4.05,"GBP":4.75}
