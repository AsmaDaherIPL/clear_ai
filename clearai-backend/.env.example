# ---- Postgres (local Docker) ----
DATABASE_URL=postgres://clearai:clearai@localhost:5432/clearai

# ---- LLM (Azure AI Foundry, Anthropic-compatible) ----
# Copy values from Foundry deployment "Details" tab.
# ANTHROPIC_BASE_URL must be the full Target URI (includes /v1/messages).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://aif-infp-dev-swc-01.services.ai.azure.com/anthropic/v1/messages
LLM_MODEL=claude-haiku-4-5-clearai-dev
# Alternate: claude-sonnet-4-6-clearai-dev (250 RPM, 250k TPM per your screenshot)

# ---- Embedder ----
EMBEDDER_MODEL=Xenova/multilingual-e5-small
EMBEDDER_DIM=384

# ---- Server ----
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
