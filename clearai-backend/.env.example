# ---- Postgres (local Docker) ----
DATABASE_URL=postgres://clearai:clearai@localhost:5432/clearai

# ---- LLM (Azure AI Foundry, Anthropic-compatible) ----
# Copy values from Foundry deployment "Details" tab.
# ANTHROPIC_BASE_URL must be the full Target URI (includes /v1/messages).
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://aif-infp-dev-swc-01.services.ai.azure.com/anthropic/v1/messages
LLM_MODEL=claude-haiku-4-5-clearai-dev
# Alternate: claude-sonnet-4-6-clearai-dev (250 RPM, 250k TPM per your screenshot)

# ---- Embedder ----
EMBEDDER_MODEL=Xenova/multilingual-e5-small
EMBEDDER_DIM=384

# ---- Server ----
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# ---- CORS (browser allowlist) ----
# Comma-separated. Leave defaults for local dev (Astro on 5173/4321).
# In prod, set to the Cloudflare Pages origin and / or the APIM gateway host.
# CORS_ORIGINS=https://clearai.pages.dev,https://apim-infp-clearai-be-dev-gwc-01.azure-api.net

# ---- APIM origin lock (production only) ----
# Shared secret that APIM injects on every forwarded request via the
# `x-apim-shared-secret` header. The Fastify auth hook rejects any
# non-/health request that doesn't carry this exact value.
# Leave UNSET in local dev — the hook is a no-op when NODE_ENV !== production.
# In prod, this is wired via Container App secretref → Key Vault.
# APIM_SHARED_SECRET=

# ---- In-app rate limit (defence-in-depth) ----
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW=1 minute

# ---- Declaration runs (bulk pipeline processing — was "BatchPlumber") ----
# Module: src/modules/declaration-runs/
# Max concurrent dispatch() calls per run (in-process p-limit semaphore).
BATCH_LLM_CONCURRENCY=8
# Reject uploads larger than this many parsed rows.
BATCH_INPUT_MAX_ROWS=1000
# Azure Blob container name for source + result files.
BATCH_BLOB_CONTAINER=declaration-runs
# Azure Blob connection string OR a `file://` URI for the local-disk fallback.
# Required at boot. Local dev: file://./.local-blob
# Prod: secretref to the Azure Storage connection string.
BATCH_BLOB_CONNECTION=file://./.local-blob
# Retention TTL for run results before background cleanup.
BATCH_RESULT_TTL_DAYS=30

# ---- ZATCA Declaration envelope (rendered as declaration_run_filings rows) ----
# Required. The decsub:saudiEDI namespace URI.
ZATCA_DECLARATION_NS=http://www.saudiedi.com/schema/decsub
# Required. Static carrier id assigned by ZATCA to the submitting operator.
ZATCA_SUBMITTER_CARRIER_ID=
# Required. Display name of the submitting operator.
ZATCA_SUBMITTER_NAME=Naqel
