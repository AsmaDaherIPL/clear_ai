meta {
  name: GET pipeline/trace/:id
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/pipeline/trace/{{lastDispatchItemId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

docs {
  Reads `declaration_run_items.id`. Currently returns 404 for items
  produced by /pipeline/dispatch (those aren't persisted). Use this with
  an item id taken from a real declaration_runs response (the
  `items[].id` field of /declaration-runs/:id/classifications).

  Returns:
    200 with the stored trace + classification result + status
    400 if the id isn't a UUID
    404 if no item has that id
}
