meta {
  name: POST pipeline/submission-description
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/pipeline/submission-description
  body: json
  auth: inherit
}

body:json {
  {
    "description": "wireless headphones",
    "code": "{{realCode}}"
  }
}

docs {
  Stage 2.5 in isolation: given a cleaned description and a 12-digit HS
  code, returns the ZATCA-safe Arabic submission text (≤300 chars).

  source enum:
    llm                       — fresh LLM output
    llm_failed                — LLM call failed; deterministic fallback
    fallback                  — LLM returned empty, used fallback
    fallback_after_collision  — LLM exact-matched the catalog, used fallback
}

assert {
  res.status: eq 200
  res.body.description_ar: isDefined
  res.body.source: matches /^(llm|llm_failed|fallback|fallback_after_collision)$/
}
