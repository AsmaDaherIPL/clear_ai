meta {
  name: POST pipeline/dispatch (with merchant_code)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/pipeline/dispatch
  body: json
  auth: inherit
}

body:json {
  {
    "description": "leather sandals",
    "merchant_code": "640299",
    "operator_slug": "{{operatorSlug}}",
    "value_amount": 150.00,
    "currency_code": "SAR"
  }
}

docs {
  Same endpoint, with a merchant-supplied 6-digit prefix. Track B will
  expand the prefix and pick a leaf; reconciliation merges with Track A.

  Use to verify the two-track pipeline behaves correctly when a code IS
  supplied. Compare `trace.track_a.chosen_code` and `trace.track_b.resolved_code`.
}

assert {
  res.status: eq 200
}
