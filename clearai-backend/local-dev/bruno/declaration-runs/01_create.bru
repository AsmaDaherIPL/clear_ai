meta {
  name: POST declaration-runs (create)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/declaration-runs
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  file: @file(./fixtures/sample-1-row.csv)
  operator_slug: {{operatorSlug}}
  mode: classify_and_declare
}

docs {
  Upload an xlsx/csv → creates a declaration_run, kicks off Phase 1
  classification in the background. Returns 202 immediately with the run
  id and poll URLs.

  Field requirements:
    file:           csv or xlsx, ≤25 MB
    operator_slug:  must exist in the operators registry
    mode:           classify_only | classify_and_declare (default the latter)

  After this returns, set the response's `declaration_run_id` into the
  collection variable `lastRunId` (Tests tab) so subsequent requests pick
  it up.
}

assert {
  res.status: eq 202
  res.body.declaration_run_id: isDefined
}

script:post-response {
  // Persist the new run id for the next requests in this folder.
  if (res.status === 202 && res.body.declaration_run_id) {
    bru.setVar('lastRunId', res.body.declaration_run_id);
  }
}
