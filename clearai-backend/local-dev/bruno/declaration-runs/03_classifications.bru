meta {
  name: GET declaration-runs/:id/classifications
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/declaration-runs/{{lastRunId}}/classifications
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

docs {
  Per-item classification results + traces. Returns 425 (Too Early) if
  Phase 1 is still running — poll `classification_status` first via the
  summary request.

  Item status enum:
    pending | classifying | succeeded | flagged | blocked | failed
}

assert {
  res.status: eq 200
  res.body.declaration_run_id: isDefined
  res.body.items: isArray
}
