meta {
  name: POST hitl/queue/:id/review (approve)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/hitl/queue/{{lastHitlId}}/review
  body: json
  auth: inherit
}

body:json {
  {
    "decision": "approve",
    "reviewer_notes": "code looks correct after manual check"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq resolved
  res.body.reviewer_decision: eq approve
}

docs {
  Resolve a HITL row by approving the system's choice.

  decision='approve' means: the code the pipeline picked is correct;
  no override needed. reviewer_code is not required for this decision.

  Body fields:
    decision        approve | override | reject
    reviewer_code   12-digit string, REQUIRED only when decision='override'
    reviewer_notes  optional, max 2000 chars

  Status transitions:
    approve / override → status='resolved'
    reject             → status='dismissed'

  Returns 409 invalid_state if the row is already terminal.
  See 05_review_override.bru and 06_review_reject.bru for the other
  two decision paths.
}
