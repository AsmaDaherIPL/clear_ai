meta {
  name: GET hitl/queue/:id
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/hitl/queue/{{lastHitlId}}
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body.id: isDefined
  res.body.classification_event_id: isDefined
  res.body.payload: isDefined
}

docs {
  Fetch a single HITL row including the full forensic `payload` jsonb
  (cleaned_description, verdict_output, sanity_result, trace).

  Uses `{{lastHitlId}}` set by the list request. Run /hitl/queue (list)
  first, or set `lastHitlId` manually in the environment.
}
