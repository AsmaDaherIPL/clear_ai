meta {
  name: GET hitl/queue (list)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/hitl/queue?operator_slug={{operatorSlug}}&status=pending&limit=50
  body: none
  auth: inherit
}

assert {
  res.status: eq 200
  res.body.items: isDefined
  res.body.total: isDefined
  res.body.limit: isDefined
}

script:post-response {
  // Stash the first row id so subsequent requests can reuse it.
  if (res.status === 200 && Array.isArray(res.body.items) && res.body.items.length > 0) {
    bru.setVar('lastHitlId', res.body.items[0].id);
  }
}

docs {
  List rows in the HITL queue. Query params:

    status         optional — pending | in_review | resolved | dismissed
    operator_slug  optional — filter to one operator (e.g. "naqel")
    limit          1-200, default 50
    offset         >=0, default 0

  Returns:
    {
      items: [...],
      total: <int>,
      limit: <int>,
      offset: <int>
    }

  Stashes the first row's id into `lastHitlId` for use by the get/claim/review
  requests below.
}
