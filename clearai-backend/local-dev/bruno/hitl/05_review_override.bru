meta {
  name: POST hitl/queue/:id/review (override)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/hitl/queue/{{lastHitlId}}/review
  body: json
  auth: inherit
}

body:json {
  {
    "decision": "override",
    "reviewer_code": "610910000000",
    "reviewer_notes": "system picked 6205 (woven shirts) but item is knitted t-shirt"
  }
}

assert {
  res.status: eq 200
  res.body.status: eq resolved
  res.body.reviewer_decision: eq override
  res.body.reviewer_code: eq 610910000000
}

docs {
  Resolve a HITL row by overriding the system's chosen code.

  decision='override' REQUIRES reviewer_code (must be exactly 12 digits).
  Without it, the endpoint returns 400 reviewer_code_required.

  Final status: 'resolved' (same as approve — the row is closed and
  the reviewer's chosen code is recorded in reviewer_code).
}
