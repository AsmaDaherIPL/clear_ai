meta {
  name: GET health
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/health
  body: none
  auth: none
}

docs {
  Liveness probe. Anonymous on both APIM (short-circuits with canned body)
  and locally (returns from Fastify with db connectivity flag).

  Expected: 200 with `{"status":"ok"}` (APIM) or `{"status":"ok","db":true}` (local).
}

assert {
  res.status: eq 200
  res.body.status: eq ok
}
