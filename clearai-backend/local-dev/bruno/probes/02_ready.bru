meta {
  name: GET ready
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/ready
  body: none
  auth: bearer
}

auth:bearer {
  token: {{bearerToken}}
}

docs {
  Readiness probe. Requires Entra JWT through APIM (validate-jwt fires).
  Locally with no `bearerToken` set, returns 200 if Fastify warmup is done
  or 503 if still warming.

  Without a token through APIM: 401.
  With a valid token: 200 ready.
  Locally (no APIM, no auth): 200 ready or 503 warming.
}
