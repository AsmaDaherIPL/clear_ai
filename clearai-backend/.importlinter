; ClearAI import-linter contract — enforces ADR-008 (hexagonal layout).
;
; Run locally:
;     .venv/bin/lint-imports
;
; In CI: fail the build if any contract is broken.
; Edit rules here ONLY after updating ADR-008 in tracker/ARCHITECTURE.md.

[importlinter]
root_packages =
    clearai
    api
    cli

; ---------------------------------------------------------------------------
; Contract 1 — outside-in only.
; api/ and cli/ are the only callers of clearai. The core never knows they
; exist; if it did, we could not add a second transport (gRPC, worker queue)
; without rewriting services.
; ---------------------------------------------------------------------------
[importlinter:contract:core-independence]
name = The clearai package must not import from api or cli
type = forbidden
source_modules =
    clearai
forbidden_modules =
    api
    cli

; ---------------------------------------------------------------------------
; Contract 2 — layered dependency direction inside clearai.
; The layers list reads high-to-low; higher layers may import from lower
; layers, never the reverse. This is what keeps ports clean of adapter
; details and adapters clean of orchestration details.
;
; Ordering rationale (top = outermost, bottom = innermost):
;   parsing   - stateless invoice intake, sits alongside services
;   services  - orchestration; composes ports + adapters
;   adapters  - concrete implementations of ports (Anthropic, future Azure)
;   ports     - abstract interfaces; domain-facing
;   domain    - pure types (empty today, reserved)
;   config    - env-var loader; every layer is allowed to read it
;
; Note: `config` is deliberately NOT in the layered list because it is a
; cross-cutting concern that the layers legitimately share. The forbidden
; contracts below keep the directionality clean without forcing config
; into a bogus layer position.
; ---------------------------------------------------------------------------
[importlinter:contract:clearai-layers]
name = clearai internal layers obey the inward-only rule
type = layers
layers =
    parsing | services
    adapters
    ports
    domain
containers =
    clearai

; ---------------------------------------------------------------------------
; Contract 3 — ports are pure.
; ports/ defines interfaces that adapters implement. If ports depended on
; adapters, the abstraction collapses: you could not add a second adapter
; without touching the port.
; ---------------------------------------------------------------------------
[importlinter:contract:ports-pure]
name = clearai.ports must not import from adapters, services, or parsing
type = forbidden
source_modules =
    clearai.ports
forbidden_modules =
    clearai.adapters
    clearai.services
    clearai.parsing

; ---------------------------------------------------------------------------
; Contract 4 — data_setup is an outer ring, not part of the hot path.
; setup.py and build_faiss.py run once at bootstrap. They are allowed to use
; config (for paths) but must not be imported by the runtime core.
; ---------------------------------------------------------------------------
[importlinter:contract:data-setup-isolated]
name = clearai runtime must not import from clearai.data_setup
type = forbidden
source_modules =
    clearai.ports
    clearai.adapters
    clearai.services
    clearai.parsing
    clearai.domain
forbidden_modules =
    clearai.data_setup
